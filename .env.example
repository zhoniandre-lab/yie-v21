# =========================================================
# YouTube Intelligence Engine — Environment Variables
# Vercel → Project → Settings → Environment Variables
# JANGAN commit file .env berisi key asli.
# =========================================================

# --- YouTube Data API (wajib untuk riset) ---
YOUTUBE_API_KEY=AIza...your_youtube_data_api_key

# --- IAMHC (primary text + image) ---
IAMHC_API_KEY=sk-...your_iamhc_key
IAMHC_BASE_URL=https://api.iamhc.cn/v1
IAMHC_MODEL=step-3.5-flash
IAMHC_STRATEGY_MODEL=Qwen3.6-35B-A3B
IAMHC_FALLBACK_MODEL=MiniMax-M2.7
# Model gambar (bukan chat). Contoh: step-image-edit-2
IAMHC_IMAGE_MODEL=step-image-edit-2

# =========================================================
# MULTI-PROVIDER ROUTER (opsional, sangat disarankan)
# Urutan: IAMHC → Groq → Gemini → OpenRouter
# Isi yang kamu punya saja. Kosongkan yang tidak dipakai.
# Sumber katalog free: github.com/cheahjs/free-llm-api-resources
# =========================================================

# --- Groq (cepat, bagus polish/fallback) ---
# Daftar: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (strategy/reasoning) ---
# Daftar: https://aistudio.google.com
# Catatan: cek kebijakan data training di region kamu
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --- OpenRouter (banyak model free/paid) ---
# Daftar: https://openrouter.ai
# Limit free ketat (~50 req/hari) → cadangan
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=https://yie-v21.vercel.app
OPENROUTER_APP_NAME=YouTube Intelligence Engine
